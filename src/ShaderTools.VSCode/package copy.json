{
  "name": "messiahsltools",
  "displayName": "MessiahSL Tools",
  "version": "1.1.403",
  "publisher": "hsy",
  "description": "Rich HLSL language support for Visual Studio Code(TimGJones)",
  "engines": {
    "vscode": "^1.102.0"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "homepage": "https://github.com/tgjones/HlslTools/tree/master/src/ShaderTools.VSCode/README.md",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "shader",
    "hlsl"
  ],
  "icon": "art/logo.png",
  "galleryBanner": {
    "color": "#5C2D91",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tgjones/HlslTools.git"
  },
  "bugs": {
    "url": "https://github.com/tgjones/HlslTools/issues"
  },
  "main": "./out/main",
  "activationEvents": [
    "onLanguage:hlsl"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "HLSL",
      "properties": {
        "hlsl-client.trace.server": {
          "scope": "window",
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5"
  },
  "devDependencies": {
    "@types/node": "^6.14.13",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^4.9.5"
  },
  "extensionDependencies": [
    "vscode.hlsl"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint src",
    "postinstall": "cd client && npm install && cd ../server && npm install && cd .."
  },
  "private": true
}